from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from dotenv import load_dotenv
import os

load_dotenv()

from langchain_openai import OpenAIEmbeddings, ChatOpenAI
from langchain_pinecone import PineconeVectorStore

app = FastAPI(title="FitGenius API", version="2.0.0")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

def detect_intent(query: str) -> str:
    q = query.lower()
    if any(w in q for w in ["eat","diet","calorie","protein",
                             "carb","fat","meal","nutrition","macro",
                             "food","drink","water","supplement"]):
        return "nutrition"
    elif any(w in q for w in ["injury","pain","hurt","knee","shoulder",
                               "back","surgery","limitation","avoid","safe"]):
        return "injury"
    else:
        return "fitness"

def build_system_prompt(intent: str) -> str:
    if intent == "injury":
        return """You are a certified fitness advisor.
The member has mentioned an injury or physical limitation.
ALWAYS prioritize safety before recommending exercises.
If the condition seems medical, recommend they consult a physician.
Only use the context provided — never fabricate information."""
    elif intent == "nutrition":
        return """You are a certified fitness and nutrition advisor.
Answer nutrition questions based ONLY on the context provided.
Give specific, practical advice grounded in the retrieved content.
Always cite which part of the source material supports your answer.
Never fabricate nutritional data."""
    else:
        return """You are a certified fitness advisor for a gym.
Answer the member's question based ONLY on the context provided.
Be specific and practical. Always cite the source material.
If the context does not contain relevant information, say so clearly.
Never make up information."""

@app.get("/health")
def health():
    return {"status": "ok", "service": "FitGenius API v2 — RAG enabled"}

class ChatRequest(BaseModel):
    message: str
    session_id: str = "default"

@app.post("/chat")
def chat(request: ChatRequest):
    try:
        # Step 1 — Detect intent
        intent = detect_intent(request.message)

        # Step 2 — Retrieve relevant chunks from Pinecone
        embeddings = OpenAIEmbeddings(model="text-embedding-3-large")
        vectorstore = PineconeVectorStore(
            index_name=os.getenv("PINECONE_INDEX_NAME"),
            embedding=embeddings
        )
        search_filter = {"category": "nutrition"} if intent == "nutrition" \
                        else {"category": "fitness"}

        docs = vectorstore.similarity_search(
            request.message,
            k=5,
            filter=search_filter
        )

        # Step 3 — Build context from retrieved chunks
        context = "\n\n---\n\n".join([doc.page_content for doc in docs])

        # Step 4 — Build dynamic prompt
        system_prompt = build_system_prompt(intent)
        full_prompt = f"""{system_prompt}

Context from certified fitness sources:
{context}

Member question: {request.message}

Answer (be specific, practical, and cite the source):"""

        # Step 5 — Call GPT-4o
        llm = ChatOpenAI(model="gpt-4o", temperature=0.3)
        result = llm.invoke(full_prompt)

        # Step 6 — Extract citations
        sources = []
        for doc in docs:
            src = doc.metadata.get("source", "Unknown")
            page = doc.metadata.get("page", "")
            citation = f"{src}" + (f", p.{page}" if page else "")
            if citation not in sources:
                sources.append(citation)

        return {
            "response": result.content,
            "sources": sources,
            "intent": intent,
            "status": "success"
        }

    except Exception as e:
        return {
            "response": f"Error: {str(e)}",
            "sources": [],
            "intent": "unknown",
            "status": "error"
        }
